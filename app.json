{
  "expo": {
    "name": "lorenta",
    "slug": "lorent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Lorenta-1.png",
    "scheme": "lorent",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.manojrustcult.rfid"
    },
    "android": {
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Lorenta-1.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "package": "com.manojrustcult.rfid"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Lorenta-1.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Lorenta-1.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "image": "./assets/images/Lorenta-1.png",
            "backgroundColor": "#FFFFFF"
          }
        }
      ],
      "react-native-ble-plx",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1dbac4db-478e-4bef-8062-e7daf4f475ec"
      }
    },
    "owner": "manojrustcult"
  }
}
